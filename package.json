{
  "name": "bullaris",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:tax": "jest --testPathPattern=packages/danish-tax",
    "lint": "turbo run lint",
    "db:push": "cd packages/db && npx prisma db push",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:seed": "cd packages/db && npx ts-node seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
